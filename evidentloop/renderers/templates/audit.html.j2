<!doctype html>
<html lang="zh-CN" data-renderer-version="{{ renderer_version }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light">
  <title>{{ title }} · EvidentLoop</title>
  <style>{{ trusted_css | safe }}</style>
</head>
<body>
  <a class="skip-link" href="#report-content">跳到报告正文</a>
  <main id="report-content" class="report-shell" data-graph-id="{{ audit.graph_id }}" data-audit-sha256="{{ source_audit_sha256 }}"{% if current_run %} data-run-id="{{ current_run.id }}"{% endif %}>
    <header class="hero review-{{ summary.review_status }} verdict-{{ summary.verdict }}"{% if current_run %} data-node-id="{{ current_run.id }}" data-node-type="run"{% endif %}>
      <div class="hero-heading">
        <div>
          <p class="kicker">EvidentLoop · 代码变更审计</p>
          <h1>{{ title }}</h1>
          {% if model_run %}<p class="hero-summary">{{ model_run.summary }}</p>{% endif %}
        </div>
        <span class="result-chip verdict-{{ summary.verdict }}">{{ report_truth.verdict }}</span>
      </div>

      <div class="truth-grid" aria-label="报告结论">
        <div class="truth-item">
          <span>审查状态</span>
          <strong>{{ report_truth.review_status }}</strong>
        </div>
        <div class="truth-item">
          <span>当前结论</span>
          <strong>{{ report_truth.verdict }}</strong>
          <small>{{ summary.open_finding_count }} 项待处理问题</small>
        </div>
        <div class="truth-item">
          <span>严重程度</span>
          <strong>{{ report_truth.overall_severity }}</strong>
        </div>
        <div class="truth-item">
          <span>旧问题验证</span>
          <strong>{{ report_truth.fix_verification }}</strong>
        </div>
      </div>

      {% if report_truth.status_note %}
      <div class="status-note" role="note">
        <strong>报告说明：</strong>{{ report_truth.status_note }}
      </div>
      {% endif %}
      {% if demo_replay %}
      <div class="status-note demo-note" data-demo-provenance="frozen-replay">
        <strong>合成演示：</strong>fixture {{ demo_fixture_id }}。没有执行实时 AI 审查。
      </div>
      {% endif %}
    </header>

    {% if changes or model_run %}
    <section class="panel change-section"{% if primary_change %} data-node-id="{{ primary_change.id }}" data-node-type="change"{% endif %}>
      <div class="section-heading">
        <div>
          <p class="eyebrow">先看业务变化</p>
          <h2>变更摘要</h2>
        </div>
        <span class="count-chip">{{ files | length }} 个文件</span>
      </div>
      {% if semantic_change_summary %}
      <article class="change-summary semantic-change-summary" data-node-id="{{ semantic_change_summary.overview.id }}" data-node-type="change"{% if semantic_change_summary.overview._edge_id %} data-edge-id="{{ semantic_change_summary.overview._edge_id }}"{% endif %}>
        <p class="change-lead">{{ semantic_change_summary.overview.summary }}</p>

        <div class="change-theme-grid" aria-label="核心实现变化">
          {% for item in semantic_change_summary.themes %}
          <section class="change-theme" data-node-id="{{ item.node.id }}" data-node-type="change"{% if item.node._edge_id %} data-edge-id="{{ item.node._edge_id }}"{% endif %}>
            <span class="change-theme-index" aria-hidden="true">{{ "%02d"|format(loop.index) }}</span>
            <div>
              <h3>{{ item.node.title }}</h3>
              <p>{{ item.node.summary }}</p>
              {% if item.impact %}<p class="change-impact"><strong>影响范围：</strong>{{ item.impact }}</p>{% endif %}
            </div>
          </section>
          {% endfor %}
        </div>

        <aside class="change-attention" aria-label="本次审计重点">
          <strong>本次审计重点</strong>
          <p>{{ semantic_change_summary.review_focus }}</p>
        </aside>

        <p class="change-stats">
          <strong>变更规模：</strong>{{ change_stats.file_count }} 个文件，新增 {{ change_stats.additions }} 行、删除 {{ change_stats.deletions }} 行{% if change_stats.binary_count %}，其中 {{ change_stats.binary_count }} 个二进制文件{% endif %}。下方保留完整文件清单和问题关联。
        </p>
      </article>
      {% else %}
      {% for change in changes %}
      <article class="change-summary" data-node-id="{{ change.id }}" data-node-type="change"{% if change._edge_id %} data-edge-id="{{ change._edge_id }}"{% endif %}>
        <h3>{{ change.title }}</h3>
        <p>{{ change.summary }}</p>
      </article>
      {% endfor %}
      {% endif %}

      {% if change_claims %}
      <div class="change-claims" aria-label="变更声明判断">
        {% for item in change_claims %}
        <article class="change-claim status-{{ item.claim.status }}{% if item.related_state %} related-{{ item.related_state }}{% endif %}" data-node-id="{{ item.owner_id }}" data-claim-id="{{ item.claim.id }}">
          <span class="claim-status">{{ item.status_label }}</span>
          <div>
            <strong>{{ item.claim.text }}</strong>
            {% if item.related_state_label %}
            <p class="claim-current-state">当前裁定：{{ item.related_state_label }}</p>
            {% endif %}
            <p>{{ item.claim.reason }}</p>
          </div>
        </article>
        {% endfor %}
      </div>
      {% endif %}

      {% if files %}
      {% if files | length > 8 %}<details class="file-list-details"><summary>查看全部 {{ files | length }} 个变更文件</summary>{% endif %}
      <div class="file-list">
        {% for file in files %}
        <div class="file-row" data-node-id="{{ file.id }}" data-node-type="file"{% if file._edge_id %} data-edge-id="{{ file._edge_id }}"{% endif %}>
          <div>
            <strong class="file-path">{{ file.path }}</strong>
            <span class="file-meta">
              <span class="add">+{{ file.get('additions', 0) }}</span>
              <span class="del">−{{ file.get('deletions', 0) }}</span>
              · {{ change_type_labels.get(file.get('change_type', 'modified'), file.get('change_type', 'modified')) }}
            </span>
          </div>
          {% if file._finding_ids %}
          <a class="issue-link" href="#{{ file._issue_link_id }}">{{ file._issue_link_label }}</a>
          {% else %}
          <span class="no-issue">未关联问题</span>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% if files | length > 8 %}</details>{% endif %}
      {% endif %}
    </section>
    {% endif %}

    {% if fix_verification_view %}
    <section class="panel fix-verification-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">独立审查当前新 diff</p>
          <h2>上一轮问题是否已解决</h2>
        </div>
        <div class="status-counts" aria-label="修复验证结果计数">
          {% for item in fix_verification_view.status_counts %}
          <span class="status-chip status-{{ item.status }}">{{ item.label }} {{ item.count }}</span>
          {% endfor %}
          {% if fix_verification_view.incomplete_count %}
          <span class="status-chip neutral">未完成 {{ fix_verification_view.incomplete_count }}</span>
          {% endif %}
        </div>
      </div>
      <p class="section-intro">这里只判断明确选择的问题，不把整个新 diff 都推断为修复。</p>
      <div class="verification-list">
        {% for target in fix_verification_view.targets %}
        <article class="verification-card status-{{ target.status }}" data-node-id="{{ fix_verification_view.owner_id }}"{% if target.claim %} data-claim-id="{{ target.claim.id }}"{% endif %}>
          <div class="verification-source">
            <span class="claim-status">{{ target.status_label }}</span>
            <div>
              <p class="label">来源问题</p>
              <h3>{{ target.source.source_title }}</h3>
              <p class="technical-id">{{ target.source.finding_id }}</p>
            </div>
          </div>
          <div class="verification-claim">
            <p class="label">用户声明</p>
            <strong>{{ target.source.claim }}</strong>
          </div>
          <div class="verification-reason">
            <p class="label">本轮判断</p>
            {% if target.claim %}
            <p>{{ target.claim.reason }}</p>
            {% if target.evidence %}
            <ul class="evidence-list">
              {% for evidence in target.evidence %}
              <li data-node-id="{{ evidence.node.id }}" data-node-type="{{ evidence.node.type }}" data-edge-id="{{ evidence.edge_id }}">
                <span>{{ '支持证据' if evidence.edge_type == 'supports_claim' else '挑战证据' }}</span>
                {{ evidence.node.summary if evidence.node.get('summary') else evidence.node.title }}
              </li>
              {% endfor %}
            </ul>
            {% else %}
            <p class="evidence-none">没有足够证据支持或挑战该声明。</p>
            {% endif %}
            {% else %}
            <p class="evidence-none">本轮没有生成该目标的有效验证结果；来源问题与用户声明仍保留。</p>
            {% endif %}
          </div>
        </article>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {% if findings %}
    <section class="panel findings-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">当前 diff</p>
          <h2>当前问题与裁定</h2>
        </div>
        <span class="count-chip">{{ findings | length }} 条</span>
      </div>
      <div class="finding-stack">
        {% for view in findings %}
        {% set finding = view.node %}
        <details id="{{ finding.id }}" class="finding-card severity-{{ finding.severity }} state-{{ finding.status }}" data-node-id="{{ finding.id }}" data-node-type="finding" data-category="{{ finding.category }}" data-severity="{{ finding.severity }}" data-fingerprint="{{ finding.fingerprint }}"{% if view.file_edge_id %} data-edge-id="{{ view.file_edge_id }}"{% endif %}{% if finding.status == 'open' %} open{% endif %}>
          <summary class="finding-header">
            <span class="finding-title-block">
              <span class="badge-row">
                <span class="finding-position" aria-label="第 {{ loop.index }} 个问题，共 {{ loop.length }} 个">问题 {{ loop.index }}/{{ loop.length }}</span>
                <span class="status-chip severity-{{ finding.severity }}">{% if finding.status == 'open' %}{{ view.severity_label }}严重度{% else %}原严重度：{{ view.model_severity_label }}{% endif %}</span>
                <span class="status-chip state-{{ finding.status }}">{{ view.status_label }}</span>
              </span>
              <span class="finding-title" role="heading" aria-level="3">{{ finding.title }}</span>
              <span class="location">{% if finding.get('file_path') %}{{ finding.file_path }}{% if finding.get('start_line') %}:{{ finding.start_line }}{% if finding.end_line != finding.start_line %}-{{ finding.end_line }}{% endif %}{% endif %}{% else %}位置未确认{% endif %}</span>
            </span>
            <span class="finding-summary-meta">
              <span class="finding-toggle-label">
                <span class="finding-toggle-closed">查看详情</span>
                <span class="finding-toggle-open">收起详情</span>
              </span>
              <svg class="details-chevron" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                <path d="m4 6 4 4 4-4"></path>
              </svg>
            </span>
          </summary>

          <div class="finding-content">
            <div class="problem-explanation{% if view.unanchored %} unanchored{% endif %}">
              <strong>{{ '语义发现，位置未精确锚定' if view.unanchored else '为什么是问题' }}</strong>
              <p>{{ finding.detail }}</p>
              {% if view.evidence_links %}
              <ul class="evidence-list compact">
                {% for link in view.evidence_links %}
                <li data-node-id="{{ link.node.id }}" data-node-type="evidence" data-edge-id="{{ link.edge_id }}">
                  <span>审查依据</span>{{ link.node.summary }}
                </li>
                {% endfor %}
              </ul>
              {% endif %}
            </div>

            {% if view.fix_links %}
            <div class="finding-fixes">
              <strong>建议怎么改</strong>
              <div class="finding-fix-list">
                {% for link in view.fix_links %}
                <div class="finding-fix" data-node-id="{{ link.node.id }}" data-node-type="fix" data-edge-id="{{ link.edge_id }}">
                  <h4>{{ link.node.title }}</h4>
                  <p>{{ link.node.detail }}</p>
                </div>
                {% endfor %}
              </div>
            </div>
            {% endif %}

            <div class="adjudication-strip" aria-label="问题裁定摘要">
              <div>
                <span>模型原判断</span>
                <strong>{{ view.model_status_label }} · {{ view.model_severity_label }}</strong>
              </div>
              <div>
                <span>已应用的我的裁定</span>
                {% if view.human_adjudication %}
                <strong>{{ view.human_disposition_label or '未改变问题结论' }}</strong>
                <small>
                  {% if view.human_severity_label %}严重度：{{ view.human_severity_label }}{% endif %}
                  {% if view.human_severity_label and view.human_adjudication.get('comment') %} · {% endif %}
                  {% if view.human_adjudication.get('comment') %}评论：{{ view.human_adjudication.comment }}{% endif %}
                </small>
                {% else %}
                <strong>无</strong>
                {% endif %}
              </div>
              <div>
                <span>待提交变化</span>
                <strong data-feedback-pending-for="{{ finding.id }}">无</strong>
              </div>
            </div>

            {% if view.hunk_view %}
            <div class="diff-block" data-hunk-id="{{ finding.hunk_id }}">
              <div class="diff-file-header">
                <strong>{{ finding.file_path }}</strong>
                <span>{{ view.hunk_view.header }}</span>
              </div>
              <div class="diff-caption">
                {% if view.hunk_view.is_excerpt %}可信节选 · {% endif %}展示 {{ view.hunk_view.displayed_line_count }}/{{ view.hunk_view.total_line_count }} 行
                · 橙色边线标记 {{ view.line_side_label }}第 {{ finding.highlight_lines | join(', ') }} 行
              </div>
              <div class="hunk-scroll" tabindex="0" aria-label="可信单栏 unified diff，可横向和纵向滚动">
                <table class="hunk-table">
                  <thead><tr><th aria-label="标记"></th><th>旧行</th><th>新行</th><th>代码</th></tr></thead>
                  <tbody>
                    {% for line in view.hunk_view.lines %}
                    {% if line.kind == 'omitted' %}
                    <tr class="hunk-omitted"><td colspan="4">… 省略 {{ line.omitted_count }} 行可信 diff 内容 …</td></tr>
                    {% else %}
                    <tr class="hunk-{{ line.kind }}{% if line.highlighted %} hunk-line-active{% endif %}"{% if line.highlighted %} data-highlighted="true"{% endif %}>
                      <td class="hunk-stripe"></td>
                      <td class="hunk-num">{{ line.old_number if line.old_number is not none else '' }}</td>
                      <td class="hunk-num">{{ line.new_number if line.new_number is not none else '' }}</td>
                      <td class="hunk-code">{{ line.prefix }}{{ line.content }}</td>
                    </tr>
                    {% endif %}
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
            {% endif %}

            <div class="feedback-panel" data-feedback-for="{{ finding.id }}" data-fingerprint="{{ finding.fingerprint }}" data-applied-disposition="{{ view.human_adjudication.get('disposition', '') }}" data-applied-comment="{{ view.human_adjudication.get('comment', '') }}" data-applied-severity="{{ view.human_adjudication.get('severity_override', '') }}">
              <div class="feedback-heading">
                <div>
                  <strong>更新我的裁定</strong>
                  <p>只记录相对当前报告的新变化，不修改代码，也不重新审查。</p>
                </div>
                <span class="status-chip neutral" data-feedback-state>待决策</span>
              </div>
              <div class="feedback-actions" role="group" aria-label="问题决策">
                <button type="button" class="button" data-feedback-action="accept" aria-pressed="false">确认有效</button>
                <button type="button" class="button" data-feedback-action="false_positive" aria-pressed="false">标记误报</button>
              </div>
              <details class="feedback-more">
                <summary>
                  评论与严重度
                  <svg class="details-chevron" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                    <path d="m4 6 4 4 4-4"></path>
                  </svg>
                </summary>
                <div class="feedback-controls">
                  <label>严重度调整
                    <select data-feedback-severity>
                      <option value="">恢复模型原严重度</option>
                      <option value="high">高</option>
                      <option value="medium">中</option>
                      <option value="low">低</option>
                      <option value="note">提示</option>
                    </select>
                  </label>
                  <label>评论
                    <textarea rows="3" maxlength="4000" placeholder="可选；清空后保存会移除已有评论" data-feedback-comment></textarea>
                  </label>
                  <div class="feedback-comment-actions">
                    <button type="button" class="button secondary" data-feedback-action="comment">保存评论</button>
                    <span role="status" aria-live="polite" data-feedback-message>尚未记录变化</span>
                  </div>
                </div>
              </details>
            </div>
          </div>
        </details>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {% if feedback_target_count %}
    <section class="panel feedback-export" aria-labelledby="feedback-export-title">
      <div>
        <p class="eyebrow">当前浏览器中的待提交变化</p>
        <h2 id="feedback-export-title">交给 AI 更新报告</h2>
        <p>内容按当前 graph、run 和问题 fingerprint 隔离；复制或下载前不会离开本页。</p>
        <p class="feedback-summary" data-feedback-summary>0 项决策 · 0 条评论 · 不自动上传</p>
        <p class="storage-status" data-feedback-storage-status>本地保存可用</p>
      </div>
      <div class="feedback-export-control">
        <div class="feedback-export-actions">
          <button type="button" class="button primary" data-feedback-copy>复制给 AI</button>
          <button type="button" class="button" data-feedback-export>下载 JSONL</button>
        </div>
        <span class="export-status" role="status" aria-live="polite" data-feedback-export-status>尚未导出</span>
      </div>
    </section>
    {% endif %}

    {% if feedback_history %}
    <section class="panel feedback-history-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">仅当前 diff</p>
          <h2>反馈与复审历史</h2>
        </div>
        <span class="count-chip">{{ feedback_history | length }} 轮</span>
      </div>
      <ol class="history-list">
        {% for item in feedback_history %}
        <li data-node-id="{{ item.run.id }}" data-node-type="run">
          <div class="history-summary">
            <strong>{{ item.run.label }}</strong>
            {% if item.summary_changes %}
            <p>报告变化：{% for change in item.summary_changes %}{{ change.label }}：{{ change.before }} → {{ change.after }}{% if not loop.last %} · {% endif %}{% endfor %}</p>
            {% else %}
            <p>报告结论未变化</p>
            {% endif %}
          </div>
          <div class="history-actions">
            <strong class="history-actions-title">本轮裁定</strong>
            <ul>
              {% for event in item.events %}
              <li class="history-event">
                <span class="history-event-target">{{ event.target_title }}</span>
                <span class="history-event-action">{{ event.label }}{% if event.value %}：{{ event.value }}{% endif %}</span>
              </li>
              {% endfor %}
            </ul>
          </div>
        </li>
        {% endfor %}
      </ol>
    </section>
    {% endif %}

    <details class="panel report-identity">
      <summary>报告身份与校验信息</summary>
      <dl>
        <div><dt>报告版本</dt><dd>{{ source_audit_sha256 }}</dd></div>
        <div><dt>Diff 版本</dt><dd>{{ audit.get('extensions', {}).get('evidentloop', {}).get('diff_version', '—') }}</dd></div>
        <div><dt>来源</dt><dd>{{ source_ref_label }}</dd></div>
        <div><dt>Schema</dt><dd>{{ audit.schema_version }}</dd></div>
        <div><dt>Graph</dt><dd>{{ audit.graph_id }}</dd></div>
        {% if fix_verification_view %}
        <div><dt>直接前驱报告</dt><dd>{{ fix_verification_view.source_report_version }}</dd></div>
        <div><dt>直接前驱 diff</dt><dd>{{ fix_verification_view.source_diff_version }}</dd></div>
        {% endif %}
      </dl>
    </details>
  </main>
  <script>{{ trusted_js | safe }}</script>
</body>
</html>
